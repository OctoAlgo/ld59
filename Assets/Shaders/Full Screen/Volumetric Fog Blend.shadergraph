    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "RayMarch",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "transmittance = 1;\r\nfloat distTravelled = 0;\r\n\r\nwhile (distTravelled < distanceLimit) {\r\n\tif (density > 0) {\r\n\t\ttransmittance *= exp(-density * stepSize);\r\n\t}\r\n\tdistTravelled += stepSize;\r\n}"
}

