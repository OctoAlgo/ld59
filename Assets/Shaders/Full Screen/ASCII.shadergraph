    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "1d357cda7e714bf286449417b848b663",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "Get_Character_Sample_UV (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -393.0000915527344,
            "y": 38.00002670288086,
            "width": 305.00006103515627,
            "height": 197.00003051757813
        }
    },
    "m_Slots": [
        {
            "m_Id": "68cf3fac1283420c9cc906522247ded5"
        },
        {
            "m_Id": "e711e20264b64ea1918261ec14212b3c"
        },
        {
            "m_Id": "8527fbd1701f4826a9b9f3b95152b55e"
        },
        {
            "m_Id": "06d45fc2d294419a9a215effcaed3dfd"
        },
        {
            "m_Id": "fa627aa6129f475db9e30873a74d53a8"
        },
        {
            "m_Id": "9324532b800e47639acdc6992bb8cee5"
        },
        {
            "m_Id": "c93839922e664cd799a5dfef0ebc79f7"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "Get_Character_Sample_UV",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float gray = saturate((ASCII_Screen_Sample.r + ASCII_Screen_Sample.g + ASCII_Screen_Sample.b) / 3.0f);\r\nint charIndex = round(gray * (Character_Count - 1));\r\nfloat coordX = ((Screen_Size.x * Screen_UV.x) % Character_Width + (Character_Width - 1) * charIndex) / ((Character_Width - 1) * Character_Count);\r\nfloat coordY = saturate(((int) (Screen_Size.y * Screen_UV.y) % Character_Height) / (Character_Height - 1));\r\nCharacter_Coord = float2(coordX, coordY);\r\n"
}

